### CSS Custom Properties
Theme colors are defined in `globals.css` with light/dark mode:
```css
:root {
  --background: #ffffff;
  --foreground: #1a1a1a;
  --border: #2a2a2a;
  --border-subtle: #e5e5e5;
  --surface: #fafafa;
  --surface-hover: #f5f5f5;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --accent-primary: #3a3a3a;
  --accent-selected: #2563eb;
  --accent-success: #10b981;
  --accent-warning: #ff9900;
  --accent-danger: #ff3333;
}

.dark {
  --background: #0f0f0f;
  --foreground: #e5e5e5;
  /* ... */
}
```

### Using CSS Variables in Tailwind
```tsx
// Preferred for complex values
className="text-[color:var(--foreground)]"
className="bg-[color:var(--surface)]"
className="border-[color:var(--border-subtle)]"

// Short form also works
className="text-[--text-secondary]"
className="bg-[--surface-hover]"
```

### Design Tokens
- **Border radius**: `rounded-[4px]` (consistent 4px corners)
- **Font**: `font-mono` for labels, buttons, headers
- **Text transforms**: `uppercase tracking-wide` for labels/buttons
- **Borders**: `border-2` (2px borders are standard)

### Common Patterns
```tsx
// Card pattern
className="rounded-[4px] border-2 border-[color:var(--border-subtle)] bg-[color:var(--background)] p-6"

// Button base
className="rounded-[4px] border-2 font-mono font-semibold uppercase tracking-wide transition"

// Section header
className="font-mono text-3xl font-bold uppercase tracking-tight text-[color:var(--foreground)]"
```

## Validation

Use Zod for schema validation:
```tsx
import { z } from 'zod'

export const envSchema = z.object({
  CUSTOMIZE_CODEBASE_STORAGE_MODE: z
    .preprocess((value) => {
      if (typeof value !== 'string') return undefined
      return value.trim().toLowerCase() || undefined
    }, z.enum(['local', 's3']).optional())
    .default('local'),
})

const parsed = envSchema.parse(process.env)
```

For form validation, use pure functions with `ValidationResult`:
```tsx
export type ValidationResult = {
  isValid: boolean
  error?: string
}

export function validateMetadataStep(formState: FormState): ValidationResult {
  if (!formState.name?.trim()) {
    return { isValid: false, error: 'Project name is required' }
  }
  return { isValid: true }
}
```

## Testing

### Unit Tests
```tsx
import { describe, it, expect, vi, beforeEach } from 'vitest'

describe('ComponentName', () => {
  beforeEach(() => {
    vi.clearAllMocks()
  })

  it('should do something', () => {
    expect(result).toBe(expected)
  })
})
```

### Component Tests
```tsx
import { render, screen, waitFor } from '@testing-library/react'

describe('MarkdownViewer', () => {
  it('should render markdown content', async () => {
    render(<MarkdownViewer url="https://example.com/test.md" />)

    await waitFor(() => {
      expect(screen.getByText(/Test Markdown/)).toBeInTheDocument()
    })
  })
})
```

## Path Aliases

Use `@/` for imports from `src/`:
```tsx
import { Button } from '@/components/ui'
import { createClient } from '@/lib/supabase/server'
import type { SessionWithProject } from '@/types/session'
```

## Utility Functions

### Class Name Utility
Use `cn()` for merging class names:
```tsx
import { cn } from '@/lib/utils/class'

className={cn(
  'base-classes',
  variant && variantClasses[variant],
  className
)}
```

## Mastra AI Agents

Agents are defined in `src/mastra/agents/`:
```tsx
import { Agent } from '@mastra/core/agent'
import { Memory } from '@mastra/memory'

export const supportAgent = new Agent({
  name: 'Support Agent',
  instructions: `Your instructions here...`,
  model: 'openai/gpt-5',
  memory: new Memory(),
})
```
