# Hissino Conventions

## Stack Overview

- **Framework**: Next.js 16 (App Router)
- **React**: 19.2 (use `useActionState`, `useFormStatus` from React 19)
- **TypeScript**: Strict mode enabled
- **Styling**: Tailwind CSS v4 with CSS custom properties
- **Database/Auth**: Supabase with `@supabase/ssr`
- **AI**: Mastra (`@mastra/core`) for agents
- **Validation**: Zod
- **Testing**: Vitest + React Testing Library

## Project Structure

```
src/
├── app/                    # Next.js App Router pages
│   ├── (auth)/            # Auth route group (login, sign-up)
│   ├── (authenticated)/   # Protected route group
│   └── api/               # API routes
├── components/
│   ├── ui/                # Base UI components (Button, Card, Input, etc.)
│   ├── layout/            # Layout components (navigation, menus)
│   ├── auth/              # Auth-specific components
│   ├── projects/          # Project feature components
│   └── sessions/          # Session feature components
├── hooks/                 # Custom React hooks
├── lib/                   # Utilities and services
│   ├── auth/              # Auth actions and utilities
│   ├── config/            # Environment and config
│   ├── supabase/          # Supabase client utilities
│   └── utils/             # General utilities
├── mastra/                # Mastra AI agents and tools
└── types/                 # TypeScript type definitions
```

## Naming Conventions

### Files
- **kebab-case** for all files: `use-projects.ts`, `form-field.tsx`, `source-code-service.ts`
- **Test files**: Co-located with source, suffix `.test.ts` or `.test.tsx`
- **Index exports**: Use `index.ts` for barrel exports in component folders

### Components
- **PascalCase** for component names: `ProjectCard`, `SessionsTable`
- **Named exports** (not default exports):
  ```tsx
  export function ProjectCard({ project }: ProjectCardProps) { ... }
  ```
- **Props interface**: `ComponentNameProps` suffix, defined above component

### Hooks
- **use-** prefix with kebab-case filename: `use-projects.ts`, `use-sessions.ts`
- **camelCase** for hook function: `useProjects`, `useSessions`

### Types
- **PascalCase** for interfaces and types: `SessionWithProject`, `AuthActionState`
- **Interface** for object shapes, **type** for unions/primitives

## Component Patterns

### Client Components
Always add `'use client'` directive at the top of client components:
```tsx
'use client'

import { useState } from 'react'
```

### UI Components (Base Components)
Use `forwardRef` pattern for components that wrap native elements:
```tsx
import { forwardRef, ButtonHTMLAttributes } from 'react'

export interface ButtonProps extends ButtonHTMLAttributes<HTMLButtonElement> {
  variant?: 'primary' | 'secondary' | 'ghost' | 'danger'
  size?: 'sm' | 'md' | 'lg'
  loading?: boolean
}

const Button = forwardRef<HTMLButtonElement, ButtonProps>(
  ({ className, variant = 'primary', size = 'md', ...props }, ref) => {
    return <button ref={ref} className={cn(baseClasses, className)} {...props} />
  }
)
Button.displayName = 'Button'

export { Button }
```

### Feature Components
Define props interface, then component:
```tsx
interface SessionsPageProps {
  initialSessions: SessionWithProject[]
  projects: ProjectWithSourceCode[]
}

export function SessionsPage({ initialSessions, projects }: SessionsPageProps) {
  // ...
}
```

### Import UI Components from Barrel
```tsx
import { Alert, Button, FormField, Input } from '@/components/ui'
```

## Hooks Pattern

Custom hooks follow a consistent state tuple pattern:
```tsx
'use client'

import { useCallback, useEffect, useMemo, useState } from 'react'

interface UseProjectsState {
  projects: ProjectWithSourceCode[]
  isLoading: boolean
  error: string | null
  refresh: () => Promise<void>
}

export function useProjects(initialProjects: ProjectWithSourceCode[] = []): UseProjectsState {
  const [projects, setProjects] = useState<ProjectWithSourceCode[]>(initialProjects)
  const [isLoading, setIsLoading] = useState<boolean>(initialProjects.length === 0)
  const [error, setError] = useState<string | null>(null)

  const fetchProjects = useCallback(async () => {
    // fetch logic...
  }, [])

  useEffect(() => {
    void fetchProjects()
  }, [fetchProjects])

  return useMemo(
    () => ({ projects, isLoading, error, refresh: fetchProjects }),
    [projects, isLoading, error, fetchProjects]
  )
}
```

## API Routes

### Structure
```tsx
import { NextResponse } from 'next/server'
import { createClient, isSupabaseConfigured } from '@/lib/supabase/server'
import { UnauthorizedError } from '@/lib/auth/server'

export const runtime = 'nodejs'

async function resolveUser() {
  const supabase = await createClient()
  const { data: { user }, error } = await supabase.auth.getUser()

  if (error || !user) {
    throw new UnauthorizedError('User not authenticated')
  }

  return { supabase, user }
}

export async function GET() {
  if (!isSupabaseConfigured()) {
    console.error('[route.get] Supabase must be configured')
    return NextResponse.json({ error: 'Supabase must be configured.' }, { status: 500 })
  }

  try {
    const { supabase, user } = await resolveUser()
    // ...
    return NextResponse.json({ data })
  } catch (error) {
    if (error instanceof UnauthorizedError) {
      return NextResponse.json({ error: 'Unauthorized.' }, { status: 401 })
    }
    console.error('[route.get] unexpected error', error)
    return NextResponse.json({ error: 'Operation failed.' }, { status: 500 })
  }
}
```

### Logging Convention
Use `[route.method]` prefix for console logs:
```tsx
console.error('[projects.get] failed to list projects', error)
console.error('[projects.id.patch] unexpected error', error)
```

