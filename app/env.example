# =============================================================================
# Required
# =============================================================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/hissuno

# Auth (AuthJS v5)
AUTH_SECRET=<generate-your-auth-secret>                    # Generate with: openssl rand -base64 32

# Automation runner - encrypts the long-lived per-project API key minted for
# skill-runner sandboxes. Without this set, automations cannot run.
AUTOMATION_KEY_ENC_SECRET=<generate-your-encryption-key>   # Generate with: openssl rand -hex 32

# AI Provider (at least one required - powers all agents and workflows)
OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# AI Model overrides (optional - defaults to OpenAI gpt-5 / gpt-5.4-mini)
# Use provider/model format: openai/gpt-5, anthropic/claude-4-5-sonnet, google/gemini-2.5-pro
# AI_MODEL=openai/gpt-5
# AI_MODEL_SMALL=openai/gpt-5.4-mini

# App URL (used for OAuth callbacks, integration redirects, and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Optional - App
# =============================================================================

# Google OAuth (for "Sign in with Google" - without this, only email/password login is available)
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Email notifications (Resend)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM_ADDRESS=Your App <hello@your-domain.com>

# Cron job authentication (secures /api/cron/* endpoints)
CRON_SECRET=<generate-with-openssl-rand-base64-32>

# Web scraping (Tavily)
TAVILY_API_KEY=tvly-your-tavily-api-key

# =============================================================================
# Optional - Integrations
# =============================================================================

# Slack
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# GitHub App (optional - only needed for GitHub App OAuth flow)
# For simpler setup, use a Personal Access Token in the project UI
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY=base64:your-base64-encoded-private-key
GITHUB_APP_SLUG=your-github-app-slug

# Atlassian / Jira
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret

# Linear
LINEAR_CLIENT_ID=your-linear-client-id
LINEAR_CLIENT_SECRET=your-linear-client-secret
LINEAR_WEBHOOK_SIGNING_SECRET=your-linear-webhook-secret

# Gong
GONG_HOST=https://us-XXXXX.api.gong.io
GONG_KEY=your-gong-key
GONG_SECRET=your-gong-secret

# Intercom
INTERCOM_CLIENT_ID=your-intercom-client-id
INTERCOM_CLIENT_SECRET=your-intercom-client-secret

# Notion
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret

# HubSpot
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret

# =============================================================================
# Optional - Storage (defaults to local filesystem)
# =============================================================================

# STORAGE_PROVIDER=s3
# S3_ENDPOINT=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=

# STORAGE_PROVIDER=vercel-blob
# BLOB_READ_WRITE_TOKEN=     # Auto-set by Vercel when Blob storage is connected
# BLOB_ACCESS=private         # 'private' (default) or 'public' - must match your Vercel Blob store config
