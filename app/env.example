# Public Secrets
NEXT_PUBLIC_APP_URL=https://your-domain.com

## Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

## Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

## Calendly
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-calendly-link

# Private

## Supabase / Database
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-1-us-east-1.pooler.supabase.com:6543/postgres

## Github Actions

### Cron (github actions)
CRON_SECRET=your-cron-secret
CRON_URL=https://your-domain.com

### NPM
NPM_TOKEN=npm_your-npm-token

## Open AI
OPENAI_API_KEY=sk-your-openai-api-key

## Scraping
TAVILY_API_KEY=tvly-your-tavily-api-key

## Email and notifications
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM_ADDRESS=Your App <hello@your-domain.com>

## Slack
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

## Github
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY=base64:your-base64-encoded-private-key
GITHUB_APP_SLUG=your-github-app-slug

## Lemon Squeezy
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMONSQUEEZY_VARIANT_ID_BASIC=your-variant-id-basic
LEMONSQUEEZY_VARIANT_ID_PRO=your-variant-id-pro
LEMONSQUEEZY_VARIANT_ID_MAX=your-variant-id-max
