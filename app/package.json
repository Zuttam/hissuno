{
  "name": "hissuno",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Customer intelligence platform - the knowledge and context layer for product AI agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuttam/hissuno.git"
  },
  "homepage": "https://hissuno.com",
  "bugs": {
    "url": "https://github.com/zuttam/hissuno/issues"
  },
  "author": "Hissuno",
  "keywords": [
    "customer-intelligence",
    "ai-agents",
    "product-feedback",
    "knowledge-base",
    "support-widget"
  ],
  "scripts": {
    "dev": "next dev --turbo",
    "build:widget": "cd packages/widget && npm run build",
    "build": "npm run build:widget && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run --exclude 'src/__tests__/integration/**'",
    "test:unit": "vitest run src/__tests__/unit/**",
    "test:integration": "vitest run src/__tests__/integration/**",
    "test:integration:pm-agent": "vitest run src/__tests__/integration/pm-agent/**",
    "test:coverage": "vitest run --coverage --exclude 'src/__tests__/integration/**'",
    "test:watch": "vitest",
    "eval:pm-agent": "npx tsx src/evals/pm-agent.eval.ts",
    "eval:pm-agent:dry": "npx tsx src/evals/pm-agent.eval.ts --dry-run",
    "eval:pm-agent:verbose": "npx tsx src/evals/pm-agent.eval.ts --verbose",
    "dev:mastra": "npx mastra dev --dir src/mastra",
    "seed": "npx tsx --tsconfig tsconfig.json src/scripts/seed.ts",
    "db:push": "ENV_FILE=${ENV_FILE:-.env.local} sh -c 'tsx --env-file $ENV_FILE ../node_modules/drizzle-kit/bin.cjs push'",
    "db:generate": "ENV_FILE=${ENV_FILE:-.env.local} sh -c 'tsx --env-file $ENV_FILE ../node_modules/drizzle-kit/bin.cjs generate'",
    "db:migrate": "ENV_FILE=${ENV_FILE:-.env.local} sh -c 'tsx --env-file $ENV_FILE ../node_modules/drizzle-kit/bin.cjs migrate'"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.65",
    "@ai-sdk/react": "^1.2.12",
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@hissuno/widget": "file:./packages/widget",
    "@linear/sdk": "^75.0.0",
    "@mastra/ai-sdk": "^1.4.1",
    "@mastra/core": "^1.28.0",
    "@mastra/e2b": "^0.2.0",
    "@mastra/libsql": "^1.9.0",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.17.1",
    "@mastra/pg": "^1.9.2",
    "@react-email/components": "^1.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.18.0",
    "@vercel/blob": "^2.3.1",
    "ai": "^5.0.87",
    "bcryptjs": "^3.0.3",
    "cron-parser": "^4.9.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-quadtree": "^3.0.1",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "drizzle-orm": "^0.45.1",
    "ignore": "^7.0.5",
    "isomorphic-git": "^1.36.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "mastra": "^1.6.3",
    "motion": "^12.23.26",
    "next": "^16.0.7",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "openai": "^4.104.0",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^9.0.1",
    "recharts": "^3.6.0",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.7.0",
    "svix": "^1.84.1",
    "tailwind-merge": "^3.4.0",
    "yaml": "^2.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@mastra/codemod": "^1.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-quadtree": "^3.0.6",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
