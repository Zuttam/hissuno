# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database Configuration (for Mastra storage)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# OpenAI Configuration (for Support Agent)
OPENAI_API_KEY=sk-your-openai-api-key

# Codebase Storage Configuration (optional)
# CUSTOMIZE_CODEBASE_STORAGE_MODE=local  # 'local' or 's3'
# CUSTOMIZE_LOCAL_STORAGE_ROOT=~/.customize
# CUSTOMIZE_S3_CODEBASE_BUCKET=customize_devs_codebases
# CUSTOMIZE_S3_REGION=us-east-1
