{
  "name": "aurora-rides",
  "private": true,
  "version": "0.1.0",
  "description": "Workspaces for the Aurora Rides reference app used with Customize.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm:dev:*\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "install:all": "npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "keywords": [
    "customize",
    "reference",
    "ride-hailing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://example.com/customize/aurora-rides.git"
  }
}

