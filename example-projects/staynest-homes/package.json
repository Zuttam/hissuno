{
  "name": "staynest-homes",
  "version": "1.0.0",
  "description": "Airbnb-style vacation rental platform example",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm:dev:*\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "install:all": "npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["example", "airbnb", "rental", "vacation"],
  "author": "",
  "license": "MIT"
}



